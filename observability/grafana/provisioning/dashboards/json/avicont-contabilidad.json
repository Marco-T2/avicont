{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["avicont", "contabilidad", "red"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "America/La_Paz",
  "title": "Avicont — Contabilidad & RED",
  "uid": "avicont-contabilidad",
  "version": 1,
  "weekStart": "",
  "refresh": "30s",
  "panels": [
    {
      "type": "row",
      "title": "Salud HTTP (RED) — funciona ahora",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Rate — requests/s por ruta",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "sum(rate(saas_http_requests_total[5m])) by (route)", "legendFormat": "{{route}}", "range": true }
      ]
    },
    {
      "type": "stat",
      "title": "Errors — % respuestas 5xx (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "sum(rate(saas_http_requests_total{status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(saas_http_requests_total[5m])), 0.001)", "range": true }
      ]
    },
    {
      "type": "stat",
      "title": "Backend up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "mappings": [ { "type": "value", "options": { "0": { "text": "CAÍDO", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "up{job=\"saas-api\"}", "range": true }
      ]
    },
    {
      "type": "timeseries",
      "title": "Duration — latencia HTTP p50/p95/p99",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 4,
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "histogram_quantile(0.50, sum(rate(saas_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "range": true },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "histogram_quantile(0.95, sum(rate(saas_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "range": true },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "histogram_quantile(0.99, sum(rate(saas_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "range": true }
      ]
    },
    {
      "type": "timeseries",
      "title": "Requests por status_code",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 5,
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "bars", "fillOpacity": 50, "lineWidth": 1, "stacking": { "mode": "normal", "group": "A" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "sum(rate(saas_http_requests_total[5m])) by (status_code)", "legendFormat": "{{status_code}}", "range": true }
      ]
    },
    {
      "type": "row",
      "title": "Dominio contable — se llenan al instrumentar (hoy en 0)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 101,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Latencia de queries a Postgres p99 (anti N+1)",
      "description": "Vacío hasta que se instrumente saas_db_query_duration_seconds en el repositorio/Prisma.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 6,
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "histogram_quantile(0.99, sum(rate(saas_db_query_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99 db", "range": true }
      ]
    },
    {
      "type": "timeseries",
      "title": "Logins por resultado (auth_login_total)",
      "description": "Vacío hasta llamar MetricsService.recordLogin() desde auth.service.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 18 },
      "id": 7,
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "sum(rate(saas_auth_login_total[5m])) by (status)", "legendFormat": "{{status}}", "range": true }
      ]
    },
    {
      "type": "timeseries",
      "title": "Operaciones autenticadas por tipo",
      "description": "Operaciones autenticadas (con tenant en JWT/header) por controller.handler. Sin tenant_id por cardinalidad; el detalle per-tenant vive en logs/traces.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 18 },
      "id": 8,
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "sum(rate(saas_tenant_operations_total[5m])) by (operation)", "legendFormat": "{{operation}}", "range": true }
      ]
    },
    {
      "type": "row",
      "title": "Runtime Node.js",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 102,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Heap usado vs total",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "id": 9,
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "saas_nodejs_heap_size_used_bytes", "legendFormat": "usado", "range": true },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "saas_nodejs_heap_size_total_bytes", "legendFormat": "total", "range": true }
      ]
    },
    {
      "type": "timeseries",
      "title": "Event loop lag p99",
      "description": "Si sube, el proceso está bloqueado (CPU sync, JSON enorme, etc.)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "id": 10,
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "saas_nodejs_eventloop_lag_p99_seconds", "legendFormat": "p99", "range": true }
      ]
    },
    {
      "type": "row",
      "title": "Logs (Loki)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 103,
      "collapsed": false
    },
    {
      "type": "logs",
      "title": "Logs del backend — errores y warnings",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 36 },
      "id": 11,
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true, "dedupStrategy": "none" },
      "targets": [
        { "refId": "A", "datasource": { "type": "loki", "uid": "loki" }, "editorMode": "code", "expr": "{service_name=\"saas-api\"} |~ \"(?i)error|warn\"", "queryType": "range" }
      ]
    }
  ]
}
