generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// IDENTIDAD Y MULTI-TENANCY
// =====================================================================
//
// Modelo flat: cada Organization es una isla. Un User puede pertenecer a
// múltiples Organizations vía Membership con distinto rol en cada una.
// Ver CLAUDE.md §5 (Seguridad y permisos) y §10.1 (Arquitectura).
//
// Roles: SystemRole (OWNER/ADMIN) hardcoded; el resto son CustomRole por
// organización con permisos como strings (Nivel B: modulo.recurso.action).
// Ver CLAUDE.md §10.4.

enum Plan {
  FREE
  PRO
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum SystemRole {
  OWNER
  ADMIN
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

// =====================================================================
// DOMINIO CONTABLE — enums compartidos
// =====================================================================

// Tipos de empresa según clasificación SIN (Bolivia). El PUCT mapea cada
// cuenta a uno o más de estos tipos. Una organización tiene UN principal
// (para reportes al SIN) y N activos (para seed del plan de cuentas).
enum TipoEmpresa {
  COMERCIAL
  SERVICIOS
  TRANSPORTE
  INDUSTRIAL
  PETROLERA
  CONSTRUCCION
  AGROPECUARIA
  MINERA
}

// Moneda funcional. BOB es la moneda funcional obligatoria en Bolivia
// (Código de Comercio Art. 37, Ley 843). USD se usa para registrar
// operaciones internacionales con tri-valor (monto + tipoCambio + montoBob).
enum Moneda {
  BOB
  USD
}

// Clase contable de la cuenta (5 valores estándar PUCT).
enum ClaseCuenta {
  ACTIVO
  PASIVO
  PATRIMONIO
  INGRESO
  EGRESO
}

// Naturaleza determina cómo afecta el saldo:
// DEUDORA: aumenta con DEBE, disminuye con HABER (Activos, Egresos)
// ACREEDORA: aumenta con HABER, disminuye con DEBE (Pasivos, Patrimonio, Ingresos)
// Excepción: cuentas contrarias (esContraria=true) tienen naturaleza opuesta
// a su clase (ej: Depreciación Acumulada vive en ACTIVO pero es ACREEDORA).
enum NaturalezaCuenta {
  DEUDORA
  ACREEDORA
}

// Sub-clasificación NIIF/PCGA, requerida para Estados Financieros.
// El Balance General separa Corriente/No Corriente.
// El Estado de Resultados separa Operativo/No Operativo.
// Nullable solo en cuentas raíz (nivel 1) que son agrupadores.
enum SubClaseCuenta {
  // Activo
  ACTIVO_CORRIENTE
  ACTIVO_NO_CORRIENTE
  // Pasivo
  PASIVO_CORRIENTE
  PASIVO_NO_CORRIENTE
  // Patrimonio
  PATRIMONIO_CAPITAL
  PATRIMONIO_RESULTADOS
  // Ingreso
  INGRESO_OPERATIVO
  INGRESO_NO_OPERATIVO
  // Egreso
  EGRESO_OPERATIVO         // Costos directos (5.1 PUCT: Costo de Ventas)
  EGRESO_ADMINISTRATIVO    // 5.2 Gastos de Administración
  EGRESO_COMERCIALIZACION  // 5.3 Gastos de Comercialización (publicidad, fletes de venta, comisiones)
  EGRESO_FINANCIERO        // 5.4 Gastos Financieros (intereses, comisiones bancarias)
  EGRESO_NO_OPERATIVO      // 5.5 Otros + 5.6 Ajustes y Diferencias de Cambio
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  hashedPassword  String
  displayName     String?
  isEmailVerified Boolean   @default(false)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  memberships             Membership[]
  refreshTokens           RefreshToken[]
  auditLogs               AuditLog[]
  invitationsSent         Invitation[]         @relation("InvitedBy")
  invitationsAccepted     Invitation[]         @relation("AcceptedBy")
  customRolesCreated      CustomRole[]         @relation("CustomRoleCreator")
  impersonationsAsAdmin   ImpersonationLog[]   @relation("ImpersonationAdmin")
  impersonationsAsTarget  ImpersonationLog[]   @relation("ImpersonationTarget")
}

model Organization {
  id     String             @id @default(uuid())
  slug   String             @unique
  name   String
  status OrganizationStatus @default(ACTIVE)

  // Plan de suscripción (lógica de cuotas en BillingService).
  plan Plan @default(FREE)

  // Feature flags de módulos. Si está deshabilitado, los endpoints del
  // módulo retornan 404/403 incluso para OWNER. Ver CLAUDE.md §10.4 y §8.3.
  contabilidadEnabled Boolean @default(true)
  granjaEnabled       Boolean @default(false)

  // Tipo de empresa principal (para reportes al SIN). INMUTABLE después
  // del primer asiento POSTED — un cambio de giro es proceso tributario
  // formal, no del sistema.
  tipoEmpresaPrincipal TipoEmpresa @default(COMERCIAL)

  // Tipos de empresa activos (para seed del plan de cuentas y sugerencias
  // del PUCT). Editable. Invariante: tipoEmpresaPrincipal ∈ tiposEmpresaActivos.
  tiposEmpresaActivos TipoEmpresa[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships         Membership[]
  customRoles         CustomRole[]
  invitations         Invitation[]
  refreshTokens       RefreshToken[]
  auditLogs           AuditLog[]
  featureFlags        FeatureFlag[]
  impersonationLogs   ImpersonationLog[]
  cuentas             Cuenta[]
  configuracionContable OrgConfiguracionContable?
  gestionesFiscales   GestionFiscal[]
  periodosFiscales    PeriodoFiscal[]
  comprobantes        Comprobante[]
  contactos           Contacto[]
  tiposDocumentoFisico          TipoDocumentoFisico[]
  documentosFisicos             DocumentoFisico[]
  comprobantesDocumentosFisicos ComprobanteDocumentoFisico[]

  @@map("organizations")
}

model Membership {
  id             String @id @default(uuid())
  organizationId String
  userId         String

  // Exactamente UNO de los dos debe estar seteado, nunca ambos ni ninguno.
  // OWNER/ADMIN son systemRole (hardcoded, no editable).
  // Cualquier otro rol es customRoleId (FK a CustomRole de la org).
  // Ver CLAUDE.md §10.4 y §8.3.
  systemRole   SystemRole?
  customRoleId String?

  deactivatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  customRole   CustomRole?  @relation(fields: [customRoleId], references: [id], onDelete: SetNull)

  @@unique([organizationId, userId])
  @@index([organizationId, deactivatedAt])
  @@index([customRoleId])
  @@map("memberships")
}

model CustomRole {
  id             String @id @default(uuid())
  organizationId String
  slug           String // ej: "contador", "granjero", "cobrador-aux"
  name           String // ej: "Contador", "Granjero"
  description    String?

  // Permisos como strings con formato {modulo}.{recurso}.{accion}.
  // Nivel B (CRUD + acciones específicas como .post, .void). Ver CLAUDE.md §2.5 y §10.2.
  // Wildcards permitidos: "contabilidad.*", "*.read".
  permissions String[]

  // Templates "Contador" y "Granjero" se precargan al crear la org.
  // El admin puede editarlos (isEditable=true) pero no eliminarlos si isSystemDefault=true.
  isSystemDefault Boolean @default(false)
  isEditable      Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("CustomRoleCreator", fields: [createdById], references: [id], onDelete: SetNull)
  memberships  Membership[]

  @@unique([organizationId, slug])
  @@index([organizationId, isSystemDefault])
  @@map("custom_roles")
}

model Invitation {
  id             String           @id @default(uuid())
  organizationId String
  email          String
  invitedById    String

  // El rol que se asignará al aceptar. Mismo patrón que Membership.
  systemRole   SystemRole?
  customRoleId String?

  // Hash SHA-256 del token enviado al usuario por email. El token claro
  // se entrega una vez en la respuesta del POST /invitations y nunca más.
  tokenHash String           @unique
  status    InvitationStatus @default(PENDING)
  expiresAt DateTime

  createdAt        DateTime  @default(now())
  acceptedAt       DateTime?
  acceptedByUserId String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitedBy", fields: [invitedById], references: [id])
  acceptedBy   User?        @relation("AcceptedBy", fields: [acceptedByUserId], references: [id])

  @@index([organizationId, status])
  @@index([email])
  @@map("invitations")
}

// =====================================================================
// AUTH: Refresh tokens con detección de reuso
// =====================================================================
//
// Familia de tokens: cada login crea una nueva familia. Cada rotación
// emite un token nuevo dentro de la misma familia y marca el viejo como
// replacedBy. Si llega un refresh ya rotado, se revoca toda la familia.
// Ver CLAUDE.md §5.3.

model RefreshToken {
  id             String  @id @default(uuid())
  tokenHash      String  @unique
  userId         String
  organizationId String?

  // familyId agrupa todos los tokens de una sesión (login → rotaciones).
  // Si se detecta reuso, se revoca toda la familia de un solo UPDATE.
  familyId     String
  replacedById String?

  expiresAt     DateTime
  revokedAt     DateTime?
  revokedReason String?

  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([familyId])
}

// =====================================================================
// AUDITORÍA Y SEGURIDAD
// =====================================================================

model AuditLog {
  id             String   @id @default(uuid())
  action         String
  entity         String
  entityId       String
  metadata       Json?
  organizationId String
  userId         String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, entity, entityId])
  @@map("audit_logs")
}

// Impersonation: cuando un OWNER/ADMIN entra al tenant de otro user.
// Toda acción durante impersonation se registra DOBLE: (a) en auditoría
// del dominio (userId = impersonado), (b) en ImpersonationAction (admin real).
// Ver CLAUDE.md §5.6 y §8.3 (Anti-27).

model ImpersonationLog {
  id             String    @id @default(uuid())
  adminUserId    String
  targetUserId   String
  organizationId String?
  reason         String
  startedAt      DateTime  @default(now())
  endedAt        DateTime?

  admin        User          @relation("ImpersonationAdmin",  fields: [adminUserId],  references: [id])
  target       User          @relation("ImpersonationTarget", fields: [targetUserId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  actions ImpersonationAction[]

  @@index([adminUserId, startedAt])
  @@index([targetUserId, startedAt])
  @@map("impersonation_logs")
}

model ImpersonationAction {
  id                 String   @id @default(uuid())
  impersonationLogId String
  action             String   // ej: "POST /api/asientos"
  resource           String?  // ej: "asiento:abc123"
  metadata           Json?
  timestamp          DateTime @default(now())

  impersonationLog ImpersonationLog @relation(fields: [impersonationLogId], references: [id], onDelete: Cascade)

  @@index([impersonationLogId, timestamp])
  @@map("impersonation_actions")
}

// =====================================================================
// DOMINIO CONTABLE — Plan de Cuentas (per-tenant)
// =====================================================================
//
// Cuenta es el plan de cuentas DEL TENANT. El plan se siembra de forma
// autocontenida desde src/cuentas/adapters/seed/. Ver CLAUDE.md §4.1.

model Cuenta {
  id             String @id @default(uuid())
  organizationId String

  // ----- Códigos -----
  // codigoInterno: hasta 8 niveles separados por punto, único por org.
  codigoInterno String

  // ----- Identidad -----
  nombre      String
  descripcion String?

  // ----- Clasificación contable -----
  claseCuenta    ClaseCuenta
  // Sub-clasificación NIIF/PCGA, requerida para EEFF.
  // Nullable solo en cuentas raíz (nivel 1) que son agrupadores puros.
  subClaseCuenta SubClaseCuenta?
  naturaleza     NaturalezaCuenta

  // ----- Jerarquía -----
  parentId String?
  // nivel persistido (1..8). Validar nivel = parent.nivel + 1 al insert/update.
  nivel    Int
  esDetalle Boolean @default(false)

  // ----- Reglas de uso -----
  // Si true, los asientos contra esta cuenta requieren contactoId.
  requiereContacto Boolean @default(false)
  // Cuenta contraria: vive en una clase pero su naturaleza es opuesta.
  // Ej: Depreciación Acumulada vive en ACTIVO pero es ACREEDORA.
  // En reportes, las contrarias se RESTAN del total de su grupo.
  esContraria      Boolean @default(false)
  // Soft-disable; no se elimina si tiene movimientos.
  activa           Boolean @default(true)

  // ----- Multi-moneda -----
  // Moneda funcional informativa (ej "Caja USD" → USD).
  monedaFuncional    Moneda  @default(BOB)
  // Si false, restringe asientos a esta moneda únicamente.
  // Ej: "Caja Moneda Nacional" → false. CxC general → true.
  permiteMultiMoneda Boolean @default(true)

  // ----- Origen -----
  // true = creada por el seed inicial al provisionar la org.
  esSystemSeed       Boolean @default(false)
  // true = el sistema la requiere para operar (IVA, Dif Cambio, Resultado Ejercicio).
  // No se puede eliminar/desactivar; solo re-mapear vía OrgConfiguracionContable.
  esRequeridaSistema Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       Cuenta?      @relation("CuentaJerarquia", fields: [parentId], references: [id])
  hijas        Cuenta[]     @relation("CuentaJerarquia")

  // Configuración contable (FKs onDelete: Restrict en OrgConfiguracionContable).
  configIvaCredito              OrgConfiguracionContable[] @relation("ConfigIvaCredito")
  configIvaDebito               OrgConfiguracionContable[] @relation("ConfigIvaDebito")
  configIvaCreditoImportaciones OrgConfiguracionContable[] @relation("ConfigIvaCreditoImp")
  configItPorPagar              OrgConfiguracionContable[] @relation("ConfigIt")
  configIuePorPagar             OrgConfiguracionContable[] @relation("ConfigIue")
  configRcIvaRetenido           OrgConfiguracionContable[] @relation("ConfigRcIva")
  configDifCambioGanancia       OrgConfiguracionContable[] @relation("ConfigDifCambioGan")
  configDifCambioPerdida        OrgConfiguracionContable[] @relation("ConfigDifCambioPer")
  configResultadoEjercicio      OrgConfiguracionContable[] @relation("ConfigResultadoEj")
  configResultadosAcumulados    OrgConfiguracionContable[] @relation("ConfigResultadosAcum")
  configCajaChicaDefault        OrgConfiguracionContable[] @relation("ConfigCajaChica")
  configAjustePorInflacion      OrgConfiguracionContable[] @relation("ConfigAjusteInflacion")

  // Líneas de comprobante que referencian esta cuenta (no se borra con movimientos)
  lineasComprobante LineaComprobante[]

  @@unique([organizationId, codigoInterno])
  @@index([organizationId, claseCuenta])
  @@index([organizationId, subClaseCuenta])
  @@index([parentId])
  @@map("cuentas")
}

// Mapeo de "conceptos contables" a cuentas específicas del tenant.
// Una sola fila por organización. Los asientos automáticos (IVA, dif. cambio,
// cierre) usan estas FKs para encontrar la cuenta correspondiente.
// FKs onDelete: Restrict — la cuenta no se puede borrar si está mapeada;
// el servicio valida que no se desactive sin re-mapear primero (Anti-35).
// Ver CLAUDE.md §10.3.
model OrgConfiguracionContable {
  organizationId String @id

  // ---- IVA (Ley 843, alícuota 13%) ----
  ivaCreditoId              String? // IVA Crédito Fiscal (compras nacionales)
  ivaDebitoId               String? // IVA Débito Fiscal (ventas)
  ivaCreditoImportacionesId String? // IVA Crédito Fiscal por importaciones (separado para control)

  // ---- Otros impuestos ----
  itPorPagarId    String? // Impuesto a las Transacciones (3% sobre ventas)
  iuePorPagarId   String? // Impuesto a las Utilidades de las Empresas (25%)
  rcIvaRetenidoId String? // Régimen Complementario al IVA retenido a empleados

  // ---- Diferencia de cambio (Norma Contable N° 6: SEPARADAS) ----
  // Ganancia: cuenta de INGRESO. Pérdida: cuenta de EGRESO.
  // Una sola cuenta no puede ser INGRESO y EGRESO simultáneamente.
  difCambioGananciaId String?
  difCambioPerdidaId  String?

  // ---- Cierre de gestión ----
  resultadoEjercicioId   String? // Resultado del Ejercicio (PATRIMONIO_RESULTADOS)
  resultadosAcumuladosId String? // Resultados Acumulados (PATRIMONIO_RESULTADOS)

  // ---- Otros ----
  cajaChicaDefaultId   String? // Cuenta default para movimientos de caja chica sin especificar
  ajustePorInflacionId String? // AITB — Ajuste Integral por Inflación (poco usado hoy, algunos sectores)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  ivaCredito              Cuenta? @relation("ConfigIvaCredito",         fields: [ivaCreditoId],              references: [id], onDelete: Restrict)
  ivaDebito               Cuenta? @relation("ConfigIvaDebito",          fields: [ivaDebitoId],               references: [id], onDelete: Restrict)
  ivaCreditoImportaciones Cuenta? @relation("ConfigIvaCreditoImp",      fields: [ivaCreditoImportacionesId], references: [id], onDelete: Restrict)
  itPorPagar              Cuenta? @relation("ConfigIt",                 fields: [itPorPagarId],              references: [id], onDelete: Restrict)
  iuePorPagar             Cuenta? @relation("ConfigIue",                fields: [iuePorPagarId],             references: [id], onDelete: Restrict)
  rcIvaRetenido           Cuenta? @relation("ConfigRcIva",              fields: [rcIvaRetenidoId],           references: [id], onDelete: Restrict)
  difCambioGanancia       Cuenta? @relation("ConfigDifCambioGan",       fields: [difCambioGananciaId],       references: [id], onDelete: Restrict)
  difCambioPerdida        Cuenta? @relation("ConfigDifCambioPer",       fields: [difCambioPerdidaId],        references: [id], onDelete: Restrict)
  resultadoEjercicio      Cuenta? @relation("ConfigResultadoEj",        fields: [resultadoEjercicioId],      references: [id], onDelete: Restrict)
  resultadosAcumulados    Cuenta? @relation("ConfigResultadosAcum",     fields: [resultadosAcumuladosId],    references: [id], onDelete: Restrict)
  cajaChicaDefault        Cuenta? @relation("ConfigCajaChica",          fields: [cajaChicaDefaultId],        references: [id], onDelete: Restrict)
  ajustePorInflacion      Cuenta? @relation("ConfigAjusteInflacion",    fields: [ajustePorInflacionId],      references: [id], onDelete: Restrict)

  @@map("org_configuracion_contable")
}

// =====================================================================
// FEATURE FLAGS (genéricos, distintos de los module flags de Organization)
// =====================================================================
//
// Para flags arbitrarios runtime (A/B tests, rollouts graduales, etc.).
// NO confundir con los flags de módulo (contabilidadEnabled, granjaEnabled)
// que viven directamente en Organization.

model FeatureFlag {
  id             String   @id @default(uuid())
  key            String
  name           String
  description    String?
  enabled        Boolean  @default(false)
  organizationId String?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([key, organizationId])
  @@index([organizationId])
  @@index([key])
  @@map("feature_flags")
}

// ============================================================
// Gestiones y períodos fiscales (Fase 1.2)
// Ver docs/disenos/gestiones-periodos-fiscales-v3.md
// ============================================================

// Gestión fiscal = ejercicio anual. Contenedor de los 12 períodos mensuales.
// El mesInicio se deriva de Organization.tipoEmpresaPrincipal (Ley 843 art. 46)
// y es inmutable una vez creada la gestión.
model GestionFiscal {
  id              String              @id @default(uuid())
  organizationId  String
  year            Int                  // año fiscal (no necesariamente calendario)
  mesInicio       Int                  // derivado de tipoEmpresaPrincipal al crear
  status          GestionFiscalStatus @default(ABIERTA)
  closedAt        DateTime?
  closedByUserId  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  periodos        PeriodoFiscal[]

  @@unique([organizationId, year])
  @@index([organizationId, status])
  @@map("gestiones_fiscales")
}

enum GestionFiscalStatus {
  ABIERTA
  CERRADA
}

// Período fiscal = mes calendario real dentro de una gestión.
// Unidad operativa donde viven los comprobantes.
// year/month son el calendario REAL (ej. gestión INDUSTRIAL 2026 tiene
// períodos desde year=2026/month=4 hasta year=2027/month=3).
model PeriodoFiscal {
  id               String              @id @default(uuid())
  organizationId   String
  gestionId        String
  year             Int
  month            Int                  // 1-12 (mes calendario)
  ordenEnGestion   Int                  // 1-12 (posición en la gestión)
  status           PeriodoFiscalStatus @default(ABIERTO)
  esDefinitivo     Boolean             @default(false)

  closedAt         DateTime?
  closedByUserId   String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  gestion          GestionFiscal            @relation(fields: [gestionId], references: [id], onDelete: Cascade)
  reopenings       PeriodoFiscalReopening[]
  comprobantes     Comprobante[]

  @@unique([organizationId, year, month])
  @@unique([gestionId, ordenEnGestion])
  @@index([organizationId, status])
  @@index([gestionId])
  @@map("periodos_fiscales")
}

enum PeriodoFiscalStatus {
  ABIERTO
  CERRADO
}

// Auditoría de reaperturas. Cada fila = una ventana de reapertura; reclosedAt
// se setea cuando se vuelve a cerrar el período.
model PeriodoFiscalReopening {
  id                 String   @id @default(uuid())
  periodoId          String
  reopenedAt         DateTime @default(now())
  reopenedByUserId   String
  motivo             String   // mínimo 20 caracteres, validado en el servicio
  reclosedAt         DateTime?
  reclosedByUserId   String?

  periodo                PeriodoFiscal          @relation(fields: [periodoId], references: [id], onDelete: Cascade)
  auditoriasComprobante  ComprobanteAuditoria[]

  @@index([periodoId])
  @@map("periodo_fiscal_reopenings")
}

// ============================================================
// Comprobantes y asientos (Fase 1.3)
// Ver docs/disenos/comprobantes-asientos.md
// ============================================================

// Tipo de comprobante: determina el prefijo de numeración (A, D, I, E, J, T, C)
// y la semántica operativa. Enum hardcoded, no configurable per-tenant.
enum TipoComprobante {
  APERTURA   // A — saldos iniciales de la gestión
  DIARIO     // D — asiento general, uso más común
  INGRESO    // I — entradas de dinero (cobros, ventas)
  EGRESO     // E — salidas de dinero (pagos, compras)
  AJUSTE     // J — ajustes, reversiones, reclasificaciones
  TRASPASO   // T — movimientos entre cuentas internas
  CIERRE     // C — cierre de cuentas de resultado (Fase 1.5)
}

// Estado del comprobante.
// Transiciones válidas: BORRADOR → CONTABILIZADO → {BLOQUEADO | ANULADO}.
// BLOQUEADO vuelve a CONTABILIZADO únicamente vía reapertura del período.
// ANULADO es terminal; la anulación crea un comprobante AJUSTE de reversión.
enum EstadoComprobante {
  BORRADOR
  CONTABILIZADO
  BLOQUEADO
  ANULADO
}

// Acción registrada en ComprobanteAuditoria.
enum AccionAuditoriaComprobante {
  CREADO
  EDITADO
  CONTABILIZADO
  ANULADO
  CREADO_POR_REVERSION
  EDIT_EN_REAPERTURA
}

// Comprobante = cabecera del asiento contable (Ley 843 art. 46, Código
// Tributario art. 47). Contiene fecha, tipo, número, estado, glosa, moneda
// principal y totales cache en BOB. El detalle vive en LineaComprobante.
model Comprobante {
  id              String            @id @default(uuid())
  organizationId  String
  tipo            TipoComprobante
  // NULL en BORRADOR. Asignado al CONTABILIZAR con formato {prefijo}{YY}{MM}-{correlativo:6}.
  numero          String?
  estado          EstadoComprobante @default(BORRADOR)

  // FechaContable: calendario puro (CLAUDE.md §4.6 core). Inmutable post-CONTABILIZADO.
  fechaContable   DateTime          @db.Date
  // Resuelto al create desde fechaContable. Inmutable post-CONTABILIZADO.
  periodoFiscalId String

  glosa           String
  monedaPrincipal Moneda            @default(BOB)

  // Totales cache en BOB, calculados al contabilizar. Validan partida doble.
  totalDebitoBob  Decimal           @default(0) @db.Decimal(18, 2)
  totalCreditoBob Decimal           @default(0) @db.Decimal(18, 2)

  // Origen de auto-entries (Fase 1.5+). En 1.3 siempre NULL. Campo presente
  // para evitar migración futura sobre tabla grande. UNIQUE ignora NULL.
  origenTipo      String?           // "VENTA" | "COMPRA" | "PAGO" | NULL
  origenId        String?           // id del documento origen

  // Anulación / reversión — una sola FK (1:1). La reversión tiene anulaAId
  // apuntando al original; el original accede a su reversión vía la back-ref
  // implícita (`reversion`) gracias a @unique([anulaAId]).
  // Metadatos de la anulación viven en el original.
  anulaAId         String?          // solo en la reversión; NULL en el original
  anuladoEn        DateTime?        // timestamptz UTC, solo en el original
  anuladoPorUserId String?          // solo en el original
  motivoAnulacion  String?          // solo en el original

  createdAt       DateTime  @default(now())
  createdByUserId String
  updatedAt       DateTime  @updatedAt

  organization   Organization           @relation(fields: [organizationId], references: [id],  onDelete: Cascade)
  periodoFiscal  PeriodoFiscal          @relation(fields: [periodoFiscalId], references: [id], onDelete: Restrict)
  lineas         LineaComprobante[]
  auditorias     ComprobanteAuditoria[]
  // Lado con FK: este comprobante es una reversión y apunta al original.
  anulaA         Comprobante?           @relation("ComprobanteReversion", fields: [anulaAId], references: [id])
  // Back-ref 1:1 (gracias a @unique([anulaAId])): si este comprobante está
  // ANULADO, su reversión es el único Comprobante cuyo anulaAId = this.id.
  reversion      Comprobante?           @relation("ComprobanteReversion")
  documentosFisicosAsociados ComprobanteDocumentoFisico[]

  // Unicidad del número por (tenant, tipo). numero es NULL en BORRADOR y
  // Postgres permite múltiples NULL en un UNIQUE, así que no colisiona.
  @@unique([organizationId, tipo, numero])

  // Unicidad de auto-entries (CLAUDE.md §4.9 core, Anti-17). NULLs ignorados
  // en 1.3 → no colisiona. Campo presente para no migrar en Fase 1.5.
  @@unique([organizationId, origenTipo, origenId])

  // Reversión 1:1 — una anulación genera exactamente una reversión.
  @@unique([anulaAId])

  @@index([organizationId, periodoFiscalId, estado])
  @@index([organizationId, fechaContable])
  @@index([organizationId, tipo, fechaContable])
  @@map("comprobantes")
}

// Líneas del comprobante = tabla de detalle donde viven los asientos (cuenta +
// monto + DEBE/HABER + moneda + tipoCambio). Multi-moneda estructural desde
// día 1 (CLAUDE.md §4.5 core): todos los campos de moneda siempre persisten,
// aunque sea BOB con tipoCambio=1.
model LineaComprobante {
  id              String   @id @default(uuid())
  organizationId  String   // denormalizado para queries cross-cuenta sin JOIN
  comprobanteId   String
  orden           Int      // 1..N dentro del comprobante; inmutable post-create

  cuentaId        String
  // Requerido si cuenta.requiereContacto = true. FK a Contacto con
  // onDelete: Restrict (contacto referenciado nunca se elimina).
  contactoId      String?

  // Multi-moneda estructural. BOB → moneda=BOB, tipoCambio=1, debitoBob=debito.
  moneda          Moneda
  debito          Decimal  @default(0) @db.Decimal(18, 2)
  credito         Decimal  @default(0) @db.Decimal(18, 2)
  tipoCambio      Decimal  @default(1) @db.Decimal(14, 8)
  debitoBob       Decimal  @default(0) @db.Decimal(18, 2)
  creditoBob      Decimal  @default(0) @db.Decimal(18, 2)

  glosaLinea      String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  comprobante     Comprobante @relation(fields: [comprobanteId], references: [id], onDelete: Cascade)
  cuenta          Cuenta      @relation(fields: [cuentaId],      references: [id], onDelete: Restrict)
  contacto        Contacto?   @relation(fields: [contactoId],    references: [id], onDelete: Restrict)

  @@unique([comprobanteId, orden])
  @@index([organizationId, cuentaId])
  @@index([organizationId, comprobanteId])
  @@index([organizationId, contactoId])
  @@map("lineas_comprobante")
}

// Contador atómico de numeración por (tenant, tipo, year, month). Se usa con
// upsert `INSERT ... ON CONFLICT DO UPDATE ... RETURNING ultimo_numero`
// para garantizar atomicidad bajo concurrencia (CLAUDE.md §4.9 core,
// Anti-24: PROHIBIDO `SELECT MAX(numero) + 1`).
model SecuenciaComprobante {
  organizationId String
  tipo           TipoComprobante
  year           Int
  month          Int              // 1-12
  ultimoNumero   Int              @default(0)

  updatedAt      DateTime         @updatedAt

  @@id([organizationId, tipo, year, month])
  @@map("secuencias_comprobante")
}

// Auditoría de comprobantes. Tabla separada del AuditLog genérico porque
// volumen y queries de negocio son específicas (drill-down por comprobante,
// filtros por reapertura). Diff es resumen (counts + totales), no snapshot.
model ComprobanteAuditoria {
  id                   String                     @id @default(uuid())
  organizationId       String
  comprobanteId        String
  userId               String
  accion               AccionAuditoriaComprobante
  diff                 Json                       // {antes, despues, campos: []}
  fueDuranteReapertura Boolean                    @default(false)
  reaperturaId         String?                    // FK a PeriodoFiscalReopening
  timestamp            DateTime                   @default(now())  // timestamptz UTC

  comprobante  Comprobante             @relation(fields: [comprobanteId], references: [id], onDelete: Cascade)
  reapertura   PeriodoFiscalReopening? @relation(fields: [reaperturaId],  references: [id], onDelete: SetNull)

  @@index([organizationId, comprobanteId, timestamp])
  @@index([organizationId, userId, timestamp])
  @@map("comprobantes_auditoria")
}

// Contacto: persona natural o jurídica con quien la asociación tiene
// vínculo contable (cliente y/o proveedor). Ver docs/disenos/contactos.md
// (Fase 1.4 slice 1) para el diseño completo.
//
// Reglas que viven en migration raw SQL (Prisma no las declara):
//   1. Unicidad parcial: (organizationId, documento) único cuando
//      documento IS NOT NULL.
//   2. CHECK ("esCliente" = true OR "esProveedor" = true) — al menos
//      un flag activo (docs/disenos/contactos.md §5.3).
//   3. Índices GIN trigram (pg_trgm) sobre razonSocial y nombreComercial
//      para búsqueda ILIKE eficiente.
model Contacto {
  id              String   @id @default(uuid())
  organizationId  String

  razonSocial     String
  nombreComercial String?
  // Texto libre, acepta NIT, CI, CEX, pasaporte u otro. NO se valida
  // formato en este slice — al implementar LCV (Fase 1.4 slice 4) se
  // endurece donde IVA lo requiera.
  documento       String?

  esCliente       Boolean  @default(false)
  esProveedor     Boolean  @default(false)

  email           String?
  telefono        String?
  direccion       String?

  activo          Boolean  @default(true)

  createdAt       DateTime @default(now())
  createdByUserId String
  updatedAt       DateTime @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lineasComprobante LineaComprobante[]
  documentosFisicos DocumentoFisico[]

  @@index([organizationId])
  @@index([organizationId, activo])
  @@index([organizationId, esCliente])
  @@index([organizationId, esProveedor])
  @@map("contactos")
}

// ============================================================
// Documentos físicos (Fase 1.4 slice 2)
// Ver openspec/changes/documento-fisico/{proposal,spec,design}.md
// ============================================================

// Tipo de documento físico: catálogo per-tenant del papel que respalda
// asientos contables. Seed universal de 8 tipos al crear la organización;
// editable y desactivable. NO eliminable si tiene documentos asociados
// (FK Restrict desde DocumentoFisico).
model TipoDocumentoFisico {
  id             String  @id @default(uuid())
  organizationId String

  // 1..100 chars, no vacío. Mostrado en UI al contador.
  nombre         String
  // 1..20 chars, kebab-case alfanumérico. Estable, único per-tenant.
  // Ancla del seed (idempotencia vía upsert por (organizationId, codigo)).
  codigo         String

  // Distingue documentos tributarios (factura, NC, ND) de no-tributarios
  // (recibo, vale, comprobante interno). Anticipa el slice 3: cuando
  // esTributario=true, exigirá Factura adjunta antes de asociar al
  // Comprobante CONTABILIZADO.
  esTributario   Boolean @default(false)

  // Soft-toggle de visibilidad. NO es soft-delete (CLAUDE.md §4.7) — este
  // modelo es catálogo, no documento contable.
  activo         Boolean @default(true)

  // Lista explícita de tipos de comprobante con los que este tipo de
  // documento puede asociarse (proposal D11). Lista vacía = ningún tipo
  // aplica (no wildcard). El service valida al asociar.
  tiposComprobanteAplicables TipoComprobante[]

  createdAt       DateTime @default(now())
  // Nullable porque el seed corre sin user context (lo crea el sistema).
  createdByUserId String?
  updatedAt       DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documentos   DocumentoFisico[]

  @@unique([organizationId, codigo])
  @@unique([organizationId, nombre])
  @@index([organizationId, activo])
  @@map("tipos_documento_fisico")
}

// DocumentoFisico = el papel que respalda asientos contables.
// Cardinalidad N:M con Comprobante vía ComprobanteDocumentoFisico.
// Inmutable cuando está asociado a un comprobante CONTABILIZADO
// (proposal D5). Eliminable solo si nunca tuvo asociaciones.
model DocumentoFisico {
  id             String  @id @default(uuid())
  organizationId String

  tipoDocumentoFisicoId String

  // Número impreso. Normalizado en VO NumeroDocumento: trim + uppercase.
  // Regex: ^[A-Z0-9./-]+$, longitud 1..50. Proposal D3: 0042 ≠ 42.
  numero         String

  // FechaContable: calendario puro, sin UTC, sin hora (CLAUDE.md §4.6).
  fechaEmision   DateTime @db.Date

  // Monto/moneda nullable por proposal D4: obligatorios solo si
  // tipo.esTributario=true. Para no-tributarios DEBE ser NULL — el monto
  // vive en el Comprobante. Validación condicional en service.
  monto          Decimal? @db.Decimal(18, 2)
  moneda         Moneda?

  // Glosa libre opcional, hasta 500 chars (validado en DTO).
  glosa          String?

  // Contacto opcional. Si esTributario=true (slice 3) será obligatorio
  // a través de Factura; en este slice se mantiene opcional para que
  // recibos sin contacto puedan registrarse.
  contactoId     String?

  createdAt       DateTime @default(now())
  createdByUserId String
  updatedAt       DateTime @updatedAt

  organization  Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Restrict: no se puede eliminar un TipoDocumentoFisico si tiene
  // documentos asociados (deuda histórica protegida).
  tipoDocumento TipoDocumentoFisico          @relation(fields: [tipoDocumentoFisicoId], references: [id], onDelete: Restrict)
  contacto      Contacto?                    @relation(fields: [contactoId], references: [id], onDelete: Restrict)
  asociaciones  ComprobanteDocumentoFisico[]

  // Defense in depth (CLAUDE.md §4.8): UNIQUE en BD + check en service.
  @@unique([organizationId, tipoDocumentoFisicoId, numero])

  @@index([organizationId, fechaEmision])
  @@index([organizationId, contactoId])
  @@index([organizationId, tipoDocumentoFisicoId])
  @@map("documentos_fisicos")
}

// Asociación N:M entre Comprobante y DocumentoFisico, a NIVEL CABECERA
// (proposal D8). organizationId denormalizado para queries y validaciones
// sin JOIN, consistente con LineaComprobante.
//
// Cardinalidad efectiva (proposal D2):
//   - Un Comprobante puede asociar 0..N DocumentosFisicos.
//   - Un DocumentoFisico puede aparecer en N comprobantes BORRADOR, pero
//     a lo sumo 1 comprobante CONTABILIZADO simultáneo.
//
// El segundo invariante se enforza con un UNIQUE PARCIAL raw SQL (Postgres
// `WHERE`) en la migration, porque Prisma no expresa unique parciales
// nativos. Nombre estable: comprobante_documento_fisico_unique_contabilizado.
model ComprobanteDocumentoFisico {
  id             String   @id @default(uuid())
  organizationId String

  comprobanteId     String
  documentoFisicoId String

  // Cache denormalizado del estado del Comprobante en el momento de la
  // asociación. Actualizado por ComprobantesService en la misma TX que
  // cambia el estado del Comprobante. Necesario para que el UNIQUE PARCIAL
  // (WHERE comprobanteEstado = 'CONTABILIZADO') funcione sin JOIN en el
  // índice. Riesgo R1 documentado en design.md.
  comprobanteEstado EstadoComprobante

  createdAt DateTime @default(now())

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // CASCADE desde Comprobante: si el comprobante se elimina (BORRADOR
  // descartado), las asociaciones se borran. Los DocumentosFisicos
  // sobreviven.
  comprobante     Comprobante      @relation(fields: [comprobanteId], references: [id], onDelete: Cascade)
  // Restrict desde DocumentoFisico: un documento físico con asociaciones
  // no se puede eliminar (queda como histórico, proposal D5).
  documentoFisico DocumentoFisico  @relation(fields: [documentoFisicoId], references: [id], onDelete: Restrict)

  // No se duplica una asociación específica.
  @@unique([documentoFisicoId, comprobanteId])

  @@index([organizationId])
  @@index([comprobanteId])
  @@index([documentoFisicoId])
  @@map("comprobante_documento_fisico")
}
